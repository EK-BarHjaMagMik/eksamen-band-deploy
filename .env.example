# Copy to `.env` on the server and fill in real values. `.env` is gitignored
# and must NEVER be committed (EKS-196). Docker Compose auto-loads this file
# from the project directory for ${VAR} substitution, and it is also injected
# into the backend container via `env_file`.
#
#   cp .env.example .env && nano .env

# --- Container images (pulled from GHCR, built by EKS-48) ---
REGISTRY=ghcr.io
BACKEND_IMAGE=ek-barhjamagmik/eksamen-band-backend
FRONTEND_IMAGE=ek-barhjamagmik/eksamen-band-frontend
IMAGE_TAG=latest

# --- TLS ---
# Email Let's Encrypt uses for expiry notices.
ACME_EMAIL=you@example.com

# --- Database (SINGLE source of truth — used by BOTH mysql and backend) ---
DB_NAME=stugg
DB_USER=stugg
DB_PASSWORD=change-me-app
DB_ROOT_PASSWORD=change-me-root

# --- Dynamic DNS (only needed once stugg.dk's DNS is on Cloudflare) ---
# Used by the standalone DDNS container documented in the README, not compose.
# Scoped API token: Zone:DNS:Edit on the stugg.dk zone only.
CF_API_TOKEN=

# --- Backups (scripts/backup-db.sh) ---
# A SEPARATE rclone remote + bucket from anything else on the box.
BACKUP_RCLONE_REMOTE=stugg-b2
BACKUP_BUCKET=stugg-db-backups
BACKUP_RETENTION_DAYS=14
